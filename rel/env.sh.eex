#!/bin/sh

# Configure Erlang distribution for Fly.io
# Required for FLAME runners to connect back to the parent node

# Get the private IPv6 address from /etc/hosts (set by Fly.io)
ip=$(grep fly-local-6pn /etc/hosts | cut -f 1)

if [ -n "$ip" ]; then
  export RELEASE_DISTRIBUTION=name
  export RELEASE_NODE=fly_code@${ip}
  # Fly.io uses IPv6 internally — Erlang distribution must use inet6_tcp
  export ERL_AFLAGS="-proto_dist inet6_tcp"
fi
